{
  "entities": {
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message sent by a visitor through the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender"
        },
        "subject": {
          "type": "string",
          "description": "Subject of the message"
        },
        "message": {
          "type": "string",
          "description": "Content of the message"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "contacts/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of contact form submissions"
    }
  }
}
